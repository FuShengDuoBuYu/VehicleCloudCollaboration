# Long-tail detector settings converted from the former car/longtail/config.yaml.
# Runtime loads .env first. If .env does not exist, it loads this .env_example.

CAR_LONGTAIL_AUTO_DOWNLOAD=true
CAR_LONGTAIL_MODEL_DIR="./car/longtail/models"

CAR_LONGTAIL_THRESHOLD=0.4986
CAR_LONGTAIL_DETECTORS="clip,yolov8,yolopv2"

CAR_LONGTAIL_CLIP_WEIGHT=0.14
CAR_LONGTAIL_CLIP_MODEL="/media/pi/FSDBY/weights/clip-vit-base-patch32"
CAR_LONGTAIL_CLIP_REMOTE_MODEL="openai/clip-vit-base-patch32"
CAR_LONGTAIL_CLIP_MAX_PROB_THRESHOLD=0.22
CAR_LONGTAIL_CLIP_ENTROPY_THRESHOLD=0.72
CAR_LONGTAIL_CLIP_LABELS="road construction with traffic cones|traffic cones on road|orange safety cones blocking the way|construction zone with cones|normal road driving scene|ordinary street scene|highway driving scene|pedestrian|car|truck|bus|motorcycle|bicycle|traffic cone|traffic bollard|road barrier|barricade|construction sign|detour sign|lane closed sign|temporary traffic sign|warning sign|arrow board|road work|traffic light|stop sign"

# This block was commented out in the old config.yaml. Add "yoloworld" to
# CAR_LONGTAIL_DETECTORS to enable it.
CAR_LONGTAIL_YOLOWORLD_WEIGHT=0.3
CAR_LONGTAIL_YOLOWORLD_MODEL="/media/pi/FSDBY/weights/yolov8x-worldv2.pt"
CAR_LONGTAIL_YOLOWORLD_REMOTE_MODEL="yolov8x-worldv2.pt"
CAR_LONGTAIL_YOLOWORLD_REMOTE_URL=""
CAR_LONGTAIL_YOLOWORLD_CONF_THRESHOLD=0.20
CAR_LONGTAIL_YOLOWORLD_CLASSES="person|car|truck|bus|motorcycle|bicycle|scooter|traffic cone|traffic bollard|road barrier|traffic barrier|barricade|construction sign|road work sign|detour sign|lane closed sign|temporary sign|arrow board|warning sign"

CAR_LONGTAIL_YOLOV8_WEIGHT=0.02
CAR_LONGTAIL_YOLOV8_MODEL="/media/pi/FSDBY/weights/yolov8n.pt"
CAR_LONGTAIL_YOLOV8_REMOTE_MODEL="yolov8n.pt"
CAR_LONGTAIL_YOLOV8_REMOTE_URL="https://github.com/ultralytics/assets/releases/download/v8.4.0/yolov8n.pt"
CAR_LONGTAIL_YOLOV8_CONF_THRESHOLD=0.25
CAR_LONGTAIL_YOLOV8_UNUSUAL_INDICATORS="stop sign|parking meter|fire hydrant"

CAR_LONGTAIL_YOLOPV2_WEIGHT=0.84
CAR_LONGTAIL_YOLOPV2_WEIGHTS="/media/pi/FSDBY/weights/yolopv2.pt"
CAR_LONGTAIL_YOLOPV2_IMG_SIZE=640
CAR_LONGTAIL_YOLOPV2_CONF_THRESHOLD=0.3
CAR_LONGTAIL_YOLOPV2_USE_FULL_MODEL=true
CAR_LONGTAIL_YOLOPV2_REMOTE_URL="https://github.com/CAIC-AD/YOLOPv2/releases/download/V0.0.1/yolopv2.pt"
CAR_LONGTAIL_YOLOPV2_DEVICE="cpu"
CAR_LONGTAIL_YOLOPV2_GEOMETRY_MODE="linear"
CAR_LONGTAIL_YOLOPV2_NEAR_MISSING_WEIGHT=0.22
CAR_LONGTAIL_YOLOPV2_CENTER_MISSING_WEIGHT=0.18
CAR_LONGTAIL_YOLOPV2_WIDTH_JUMP_WEIGHT=0.24
CAR_LONGTAIL_YOLOPV2_CENTER_JUMP_WEIGHT=0.16
CAR_LONGTAIL_YOLOPV2_LANE_ANOMALY_WEIGHT=0.10
CAR_LONGTAIL_YOLOPV2_WIDTH_STD_WEIGHT=0.10
CAR_LONGTAIL_YOLOPV2_LINEAR_COEFFICIENTS="0.408258|0.611690|0.900184|0.261055|0.375240|-2.352794|6.273399|-2.959277|-1.691969|-3.064723"
CAR_LONGTAIL_YOLOPV2_LINEAR_INTERCEPT=0.554888
CAR_LONGTAIL_YOLOPV2_LINEAR_TEMPERATURE=1.0
